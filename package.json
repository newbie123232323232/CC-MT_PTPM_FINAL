{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "heroku-postbuild": "npm run install-client && npm run build",
    "server": "nodemon index.js",
    "develop": "concurrently --kill-others-on-fail \"npm run server\" \"npm run start --prefix client\"",
    "start": "node index.js",
    "seed:phase1": "node scripts/seedPhase1.js",
    "smoke:step9": "node scripts/smokeStep9.js",
    "test": "node --test tests/*.test.js",
    "test:integration": "node --test tests/integration-flow.test.js",
    "bootstrap:dev": "node scripts/bootstrapDev.js",
    "db:profiles": "node scripts/listProfiles.js",
    "trending:refresh": "node scripts/refreshTrending.js"
  },
  "keywords": [],
