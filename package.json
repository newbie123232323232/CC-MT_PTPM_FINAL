  "license": "ISC",
  "dependencies": {
    "crypto-js": "^4.1.1",
    "dotenv": "^16.0.1",
    "express": "^4.18.1",
    "google-auth-library": "^9.14.0",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^6.3.4",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.4",
    "nodemon": "^2.0.16",
    "socket.io": "^4.8.3"
  }
