# Sao chép thành `.env` và điền giá trị. Không commit `.env`.

MONGO_URL=mongodb://127.0.0.1:27017/netflix
SECRET_KEY=
PORT=5000

# Đăng nhập Google (Web client ID — cùng giá trị với REACT_APP_GOOGLE_CLIENT_ID ở client)
# GOOGLE_CLIENT_ID=

# Tuỳ chọn — URL tuyệt đối trả về sau upload (admin → API). Mặc định: http://localhost:PORT
# PUBLIC_UPLOAD_BASE=http://localhost:5000

# URL web client (link reset mật khẩu trong email)
FRONTEND_URL=http://localhost:3000

# Gmail (App Password): https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Tuỳ chọn — mặc định dùng service gmail trong code
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
